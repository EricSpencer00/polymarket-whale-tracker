# Polymarket whale tracker — local config (do not commit your real .env).
# Every value here is OPTIONAL. The tracker is fully read-only and works
# without any credentials against Polymarket's public REST + WSS APIs.

# Directory where discover/analyze write their JSONL snapshots.
POLYWHALE_DATA_DIR=./data

# Comma-separated proxy-wallet addresses to watch by default.
# Example: a known BTC market-maker whale.
POLYWHALE_WATCHLIST=

# Optional logging level: DEBUG | INFO | WARNING | ERROR
POLYWHALE_LOG_LEVEL=INFO
